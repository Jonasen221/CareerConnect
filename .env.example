# Copy this file to `.env.local` and fill in your Supabase project values.
# Both variables are read by Vite at build time.

VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Optional (local dev only): skip “pending approval” UI so non-admins can click through
# VITE_SKIP_APPROVAL_GATES=true
